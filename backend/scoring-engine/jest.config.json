{
  "preset": "ts-jest",
  "testEnvironment": "node",
  "roots": [
    "<rootDir>/__tests__",
    "<rootDir>/src"
  ],
  "testMatch": [
    "**/__tests__/**/*.test.ts"
  ],
  "moduleFileExtensions": [
    "ts",
    "tsx",
    "js",
    "jsx"
  ],
  "collectCoverageFrom": [
    "src/**/*.ts",
    "!src/**/*.d.ts",
    "!src/index.ts"
  ],
  "coveragePathIgnorePatterns": [
    "/node_modules/"
  ]
}
